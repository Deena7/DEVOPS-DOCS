WORKDIR /app
COPY package.json .
RUN npm install
COPY server.js .
CMD ["node","server.js"]

db/init.sql
=================================
CREATE DATABASE appdb;

USE appdb;

CREATE TABLE users (
 id INT AUTO_INCREMENT PRIMARY KEY,
 username VARCHAR(100),
 password VARCHAR(100)
);



docker-compose.yaml
===============================
version: "3.8"

services:

 frontend:
   build: frontend
   ports:
     - "80:80"
   depends_on:
     backend:
       condition: service_started

 backend:
   build: backend
   ports:
     - "3000:3000"
   depends_on:
     db:
       condition: service_healthy
   restart: always

 db:
   image: mysql:8
   environment:
     MYSQL_ROOT_PASSWORD: root
   volumes:
     - ./db/init.sql:/docker-entrypoint-initdb.d/init.sql
   healthcheck:
     test: ["CMD","mysqladmin","ping","-uroot","-proot"]
     interval: 5s
     timeout: 5s
     retries: 5


